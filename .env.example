# --- Linkup (required) -------------------------------------------------------
# The engine. Get a key at https://app.linkup.so  ->  Settings  ->  API.
LINKUP_API_KEY=

# --- LLM provider (pick one; Anthropic is the default) -----------------------
# The reasoning/formatting layer on top of Linkup. Swap freely — see docs/06-providers.md.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# --- Optional connectors (only set what a given agent uses) ------------------
# CRM
# HUBSPOT_ACCESS_TOKEN=
# SALESFORCE_ACCESS_TOKEN=
# ATTIO_API_KEY=
# Calendar / email
# GOOGLE_CALENDAR_CREDENTIALS_JSON=
# RESEND_API_KEY=
# Destinations
# NOTION_API_KEY=
# SLACK_BOT_TOKEN=
